# DS-APM VM용 OTel Collector 설치 설정.
# 사용법: 이 파일을 dsapm-collector.env 로 복사해 값을 채운 뒤 sudo ./install.sh
#   cp dsapm-collector.env.example dsapm-collector.env
#   chmod 600 dsapm-collector.env      # 비번 평문 보호(install.sh도 강제)
# 이 .env 파일(실제 값)은 절대 커밋하지 마세요. .example 만 커밋합니다.

# ── 필수 ─────────────────────────────────────────────
DS_APM_HOST=                 # DS-APM 수신 호스트 (IP/도메인, 포트 제외). install.sh가 :4317을 붙임.
                             #   예: 10.0.0.5  또는  apm.example.com   (":4317" 넣지 말 것)

# ── Collector 버전 ───────────────────────────────────
OTELCOL_VERSION=0.139.0      # 권장: 핀 고정. 비우면 GitHub 최신 릴리스 자동 조회 —
                             #   단 재실행마다 최신을 좇아 "말없이 업그레이드"됨(멱등 아님). fleet은 반드시 고정.

# ── PostgreSQL 리시버 토글 ───────────────────────────
ENABLE_POSTGRESQL=false      # true면 아래 PG_* 필요
PG_ENDPOINT=localhost:5432
PG_MONITORING_USER=monitoring
PG_MONITORING_PASSWORD=<CHANGE_ME>   # 모니터링 계정 비번. systemd EnvironmentFile로 POSTGRES_PASSWORD로 주입됨.
PG_DATABASES=petclinic       # 쉼표구분. 비우면 전체 DB.

# ── 고급(기본값 유지) ────────────────────────────────
DS_APM_ENDPOINT=             # 지정 시 DS_APM_HOST:4317 대신 이 값을 exporter endpoint로 그대로 사용(포트 포함)
OTLP_GRPC_ENDPOINT=0.0.0.0:4317
OTLP_HTTP_ENDPOINT=0.0.0.0:4318
COLLECTION_INTERVAL=60s
TLS_INSECURE=true            # 콜렉터→DS-APM 구간 TLS 미검증. 신뢰 못 하는 경로면 false + 인증서 신뢰 구성.
