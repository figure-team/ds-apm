# syntax=docker/dockerfile:1

# Stage 1: Go binary
FROM golang:1.25-alpine AS go-builder
WORKDIR /src
COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download
# Copy only the Go source trees (all *.go live under cmd/ and pkg/, and every
# //go:embed target is inside pkg/). Copying the whole repo here pulled in
# frontend/ too, so any frontend edit busted this layer and forced a full Go
# rebuild that then fought the frontend build for CPU.
COPY cmd ./cmd
COPY pkg ./pkg
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -tags timetzdata \
    -o /out/signoz-community \
    -ldflags "-s -w -X github.com/SigNoz/signoz/pkg/version.variant=community" \
    ./cmd/community

# Stage 2: Frontend
FROM node:22-alpine AS js-builder
WORKDIR /frontend
# yarn 1.x writes its package cache to ~/.cache/yarn by default, so the build
# cache mount below (target=/root/.yarn) caught nothing and every install layer
# rebuild re-downloaded all deps. Redirect the cache dir into the mounted path
# so it actually persists across builds.
ENV YARN_CACHE_FOLDER=/root/.yarn
# Copy only the manifest + the two files postinstall actually touches
# (i18-generate-hash.cjs and scripts/update-registry.cjs). Copying the whole
# scripts/ dir keyed this layer on every i18n-tooling edit, busting the install
# cache for changes the dependency install never needs.
COPY frontend/package.json frontend/yarn.lock frontend/i18-generate-hash.cjs ./
COPY frontend/scripts/update-registry.cjs ./scripts/update-registry.cjs
RUN --mount=type=cache,target=/root/.yarn \
    CI=1 yarn install --frozen-lockfile --prefer-offline --silent
COPY frontend/ .
# Regenerate the i18n hash now that public/locales is present (at install time
# it ran against an empty tree and wrote {}), then build.
RUN --mount=type=cache,target=/root/.yarn \
    CI=1 yarn i18n:generate-hash && CI=1 yarn build

# Stage 3: Final image
FROM alpine:3.20.3
LABEL maintainer="signoz"
WORKDIR /root

# ca-certificates: TLS roots for outbound HTTPS (LLM api transport / git fetch).
# nodejs+npm: runtime for the `claude` CLI (LLM cli transport).
# ripgrep+git: claude-code shells out to these; the bundled musl-incompatible
#   ripgrep is disabled via USE_BUILTIN_RIPGREP=0 so the system one is used.
# bash: the auto-remediation executor runs approved Runbook scripts via `bash -c`
#   (scripts use `#!/usr/bin/env bash` + `set -euo pipefail`); Alpine ships only
#   busybox sh, so without bash every execution exits -1 (bash: not found).
# docker-cli: a restart-type Runbook script (e.g. SOP-AD-001) shells out to
#   `docker restart <container>` against the host docker.sock mounted into this
#   container (see docker-compose.local.yaml). musl-native, so no static binary.
# util-linux: setpriv/prlimit for the local remediation sandbox — llm-generated
#   scripts are demoted to the non-root `remed` user (fail-closed without it);
#   runbook scripts get best-effort prlimit resource caps.
RUN apk update && \
    apk add --no-cache ca-certificates nodejs npm ripgrep git bash docker-cli util-linux && \
    npm install -g @anthropic-ai/claude-code && \
    rm -rf /var/cache/apk/* /root/.npm && \
    adduser -D -H -s /sbin/nologin remed
ENV USE_BUILTIN_RIPGREP=0

COPY --from=go-builder /out/signoz-community ./signoz
COPY --from=js-builder /frontend/build/ /etc/signoz/web/
COPY templates/email /root/templates

RUN chmod 755 /root/signoz

ENTRYPOINT ["./signoz", "server"]
